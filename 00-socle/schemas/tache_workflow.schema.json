{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adminquest.github.io/crc-control-workflow/schemas/tache_workflow.schema.json",
  "title": "TacheWorkflow",
  "type": "object",
  "required": ["id", "module", "intitule", "responsable", "statut", "priorite"],
  "properties": {
    "id": {"type": "string", "pattern": "^T-[0-9]{2}-[0-9]{3}$"},
    "module": {"type": "string", "pattern": "^[0-9]{2}-[a-z0-9-]+$"},
    "intitule": {"type": "string"},
    "objectif": {"type": "string"},
    "responsable": {"type": "string", "enum": ["rapporteur", "verificateur", "binome", "president_section", "ministere_public", "autre"]},
    "livrable": {"type": "string"},
    "entrees": {"type": "array", "items": {"type": "string"}},
    "sorties": {"type": "array", "items": {"type": "string"}},
    "controle_qualite": {"type": "string"},
    "priorite": {"type": "string", "enum": ["haute", "normale", "basse"]},
    "statut": {"type": "string", "enum": ["a_faire", "en_cours", "a_revoir", "terminee", "abandonnee"]},
    "echeance": {"type": "string"},
    "commentaire": {"type": "string"}
  }
}
